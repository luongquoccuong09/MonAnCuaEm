@inject RecipeService RecipeService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Rounded.AddCircle" Class="mr-2" />
            Chọn món — @Meal.ToVietnamese(), @Date.WeekdayVi() @Format.ShortDate(Date)
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_recipes is null)
        {
            <div class="d-flex justify-center pa-6"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
        }
        else if (_recipes.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="my-2">
                Chưa có món nào. Hãy vào mục <b>Món ăn</b> để tạo món trước nhé!
            </MudAlert>
        }
        else
        {
            <MudTextField @bind-Value="_search" Placeholder="Tìm món..." Immediate="true" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search" Class="mb-2" />
            <MudList T="Recipe" Dense="true" Style="max-height:50vh; overflow:auto;">
                @foreach (var r in Filtered)
                {
                    <MudListItem T="Recipe" OnClick="() => Select(r)">
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Rounded="true" Size="Size.Medium">
                                @if (!string.IsNullOrEmpty(r.ImageData))
                                {
                                    <MudImage Src="@r.ImageData" ObjectFit="ObjectFit.Cover" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Rounded.Restaurant" />
                                }
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.body1"><b>@r.Name</b></MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @r.Category.ToVietnamese() • @Format.Money(r.TotalCost)
                                </MudText>
                            </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Huỷ</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateOnly Date { get; set; }
    [Parameter] public MealType Meal { get; set; }

    private List<Recipe>? _recipes;
    private string _search = string.Empty;

    private IEnumerable<Recipe> Filtered =>
        string.IsNullOrWhiteSpace(_search)
            ? _recipes!
            : _recipes!.Where(r => r.Name.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _recipes = await RecipeService.GetAllAsync();
    }

    private void Select(Recipe r) => MudDialog.Close(DialogResult.Ok(r.Id));

    private void Cancel() => MudDialog.Cancel();
}
