@page "/mon-an"
@inject RecipeService RecipeService
@inject MealPlanService MealPlanService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Món ăn — Món Ăn Của Em</PageTitle>

<div class="d-flex align-center justify-space-between flex-wrap gap-3 mb-4">
    <div>
        <MudText Typo="Typo.h4"><b>Món ăn</b></MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Thư viện công thức của gia đình mình</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               Class="rounded-lg" OnClick="() => OpenRecipeDialog(null)">Thêm món</MudButton>
</div>

<MudTextField @bind-Value="_search" Placeholder="Tìm món theo tên..." Variant="Variant.Outlined" Immediate="true"
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search" Class="mb-4" />

@if (_loading)
{
    <div class="d-flex justify-center pa-10"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
}
else if (_recipes.Count == 0)
{
    <MudPaper Elevation="1" Class="pa-10 d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Rounded.RamenDining" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Class="mt-2">Chưa có món nào</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">Bắt đầu bằng cách thêm món ăn đầu tiên nhé!</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
                   OnClick="() => OpenRecipeDialog(null)">Thêm món</MudButton>
    </MudPaper>
}
else
{
    foreach (var category in DisplayNames.AllCategories)
    {
        var items = InCategory(category).ToList();
        if (items.Count == 0) continue;

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">@category.ToVietnamese() <span class="mud-text-secondary">(@items.Count)</span></MudText>
        <MudGrid Spacing="3">
            @foreach (var r in items)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" Class="h-100 d-flex flex-column">
                        @if (!string.IsNullOrEmpty(r.ImageData))
                        {
                            <MudCardMedia Image="@r.ImageData" Height="160" />
                        }
                        else
                        {
                            <div class="recipe-placeholder d-flex align-center justify-center" style="height:160px; background:#F1ECFA;">
                                <MudIcon Icon="@Icons.Material.Rounded.Restaurant" Size="Size.Large" Color="Color.Secondary" />
                            </div>
                        }
                        <MudCardContent Class="flex-grow-1">
                            <MudText Typo="Typo.h6">@r.Name</MudText>
                            <div class="d-flex align-center gap-2 my-1">
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">@r.Category.ToVietnamese()</MudChip>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@Format.Money(r.TotalCost)</MudChip>
                            </div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@r.Ingredients.Count nguyên liệu</MudText>
                            @if (!string.IsNullOrWhiteSpace(r.Memory))
                            {
                                <MudText Typo="Typo.body2" Class="memory-note mt-2">
                                    <MudIcon Icon="@Icons.Material.Rounded.Favorite" Size="Size.Small" Color="Color.Tertiary" /> @r.Memory
                                </MudText>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Rounded.Edit" Color="Color.Primary" OnClick="() => OpenRecipeDialog(r)" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" OnClick="() => DeleteRecipe(r)" />
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    private List<Recipe> _recipes = new();
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _recipes = await RecipeService.GetAllAsync();
        _loading = false;
    }

    private IEnumerable<Recipe> InCategory(MealCategory c) =>
        _recipes.Where(r => r.Category == c &&
            (string.IsNullOrWhiteSpace(_search) || r.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)));

    private async Task OpenRecipeDialog(Recipe? existing)
    {
        var model = existing?.Clone() ?? new Recipe();
        var parameters = new DialogParameters
        {
            ["Recipe"] = model,
            ["IsEdit"] = existing is not null
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<RecipeDialog>(existing is null ? "Thêm món" : "Sửa món", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is Recipe saved)
        {
            await RecipeService.SaveAsync(saved);
            await Load();
            Snackbar.Add("Đã lưu món ăn 💜", Severity.Success);
        }
    }

    private async Task DeleteRecipe(Recipe r)
    {
        bool? confirmed = await DialogService.ShowMessageBox(
            "Xoá món ăn",
            $"Bạn có chắc muốn xoá \"{r.Name}\"? Món này cũng sẽ bị gỡ khỏi lịch thực đơn.",
            yesText: "Xoá", cancelText: "Huỷ");
        if (confirmed == true)
        {
            await RecipeService.DeleteAsync(r.Id);
            await MealPlanService.RemoveRecipeAsync(r.Id);
            await Load();
            Snackbar.Add("Đã xoá món.", Severity.Info);
        }
    }
}
